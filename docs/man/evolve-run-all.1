.TH "EVOLVE" "1" "Jul 2026" "Auto generated by spf13/cobra" ""

.SH NAME
evolve-run-all - Run everything: checks, triggers, evals, then regenerate reports


.SH SYNOPSIS
\fBevolve run all [flags]\fP


.SH DESCRIPTION
Run everything: checks, triggers, evals, then regenerate reports


.SH OPTIONS
\fB--baseline\fP[=true]
	benchmark each eval without the skill (its lift), recomputed only when the eval or its fixtures change (disable with --baseline=false; config: baseline)

.PP
\fB--count-only\fP[=false]
	skip agent runs; only compute token usage per model

.PP
\fB--failed\fP[=false]
	only run evals that did not pass on a previous run (combine with --new to also rerun missing ones)

.PP
\fB--harness\fP=[]
	only drive models with these harnesses: claude, codex, gemini, cursor, copilot, antigravity (repeatable / comma-separated; alias: --harnesses; filters within config harnesses)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for all

.PP
\fB--jobs\fP=4
	concurrent agent runs (default: ceil(cpus/2))

.PP
\fB--keep-workspaces\fP[=false]
	keep throwaway workspaces for debugging

.PP
\fB--max-turns\fP=20
	max agent turns per eval (config: max_turns; a per-eval max_turns overrides both)

.PP
\fB--model\fP=[]
	provider ids / canonical model ids, or "all" (repeatable / comma-separated; alias: --models; filters within config models)

.PP
\fB--modified\fP[=false]
	only run evals whose authored skill content or case definition changed since their stored results

.PP
\fB--new\fP[=false]
	only run evals whose stored results are missing values a rerun could fill

.PP
\fB--no-tui\fP[=false]
	disable the interactive TUI even on a terminal (also: EVOLVE_NO_TUI=1)

.PP
\fB--plugin\fP=[]
	only run evals for these plugins (repeatable / comma-separated; alias: --plugins)

.PP
\fB--runs\fP=3
	runs per query (triggers tier)

.PP
\fB--skill\fP=[]
	only run evals for these skills (repeatable / comma-separated; alias: --skills)

.PP
\fB--stale-results\fP=""
	keep|drop stored results for models outside the models restriction (default: prompt on a terminal, else keep)

.PP
\fB--timeout\fP=120 triggers, 600 evals
	seconds per agent run


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--json\fP[=false]
	emit machine-readable JSONL progress on stdout

.PP
\fB--layout\fP="auto"
	repository layout: auto, marketplace, multi, or single

.PP
\fB--no-sandbox\fP[=false]
	disable the OS sandbox that confines agent writes to the workspace (config: sandbox.enabled)

.PP
\fB--results-format\fP=""
	format for results files and the EVALUATION rollup: json, jsonc, or yaml (default: config results_format or json)

.PP
\fB--root\fP=""
	repository root to operate on (default: walk up from the current directory)

.PP
\fB--strict\fP[=false]
	exit 1 when checks or evals fail (default: warn and exit 0)

.PP
\fB--telemetry-dir\fP=""
	write OpenTelemetry traces/metrics/logs as JSON to this directory (default: off; overrides OTEL_* env vars)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable debug logging


.SH SEE ALSO
\fBevolve-run(1)\fP
