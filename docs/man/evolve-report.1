.TH "EVOLVE" "1" "Jul 2026" "Auto generated by spf13/cobra" ""

.SH NAME
evolve-report - Regenerate EVALUATION.md and EVALUATION.json from the stored results


.SH SYNOPSIS
\fBevolve report [flags]\fP


.SH DESCRIPTION
Regenerate EVALUATION.md and EVALUATION.json from the stored results


.SH OPTIONS
\fB--check\fP[=false]
	fail when pass rates breach the configured thresholds

.PP
\fB--cobertura\fP=""
	also write a Cobertura XML coverage file to this path (overrides report.cobertura)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for report

.PP
\fB--junit\fP=""
	also write a JUnit XML test-results file to this path (overrides report.junit)

.PP
\fB--migrate\fP[=false]
	upgrade stored results files to the latest schema before generating the reports

.PP
\fB--min-evals-pass-rate\fP=0
	minimum eval pass rate (0..1) for --check

.PP
\fB--min-triggers-pass-rate\fP=0
	minimum trigger pass rate (0..1) for --check

.PP
\fB--stale-results\fP=""
	keep|drop stored results for models outside the models restriction (default: prompt on a terminal, else keep)

.PP
\fB--strict\fP[=false]
	require the configured model matrix: --check holds every defined model to the thresholds, and --cobertura covers a skill only when every defined model has a current result


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--json\fP[=false]
	emit machine-readable JSONL progress on stdout

.PP
\fB--layout\fP="auto"
	repository layout: auto, marketplace, multi, or single

.PP
\fB--results-format\fP=""
	format for results files and the EVALUATION rollup: json, jsonc, or yaml (default: config results_format or json)

.PP
\fB--root\fP=""
	repository root to operate on (default: walk up from the current directory)

.PP
\fB--telemetry-dir\fP=""
	write OpenTelemetry traces/metrics/logs as JSON to this directory (default: off; overrides OTEL_* env vars)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable debug logging


.SH SEE ALSO
\fBevolve(1)\fP
