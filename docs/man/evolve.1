.nh
.TH "EVOLVE" "1" "Jul 2026" "" ""

.SH NAME
evolve - Evaluate coding-agent plugins: static checks, trigger accuracy, behavioral evals, reports


.SH SYNOPSIS
\fBevolve [flags]\fP


.SH DESCRIPTION
Evaluate coding-agent plugins: static checks, trigger accuracy, behavioral evals, reports


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for evolve

.PP
\fB--json\fP[=false]
	emit machine-readable JSONL progress on stdout

.PP
\fB--layout\fP="auto"
	repository layout: auto, marketplace, multi, or single

.PP
\fB--results-format\fP=""
	format for results files and the EVALUATION rollup: json, jsonc, or yaml (default: config results_format or json)

.PP
\fB--root\fP=""
	repository root to operate on (default: walk up from the current directory)

.PP
\fB--telemetry-dir\fP=""
	write OpenTelemetry traces/metrics/logs as JSON to this directory (default: off; overrides OTEL_* env vars)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable debug logging


.SH SEE ALSO
\fBevolve-completion(1)\fP, \fBevolve-doctor(1)\fP, \fBevolve-models(1)\fP, \fBevolve-report(1)\fP, \fBevolve-run(1)\fP, \fBevolve-version(1)\fP, \fBevolve-view(1)\fP
