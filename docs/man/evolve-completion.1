.TH "EVOLVE" "1" "Jul 2026" "Auto generated by spf13/cobra" ""

.SH NAME
evolve-completion - Generate the autocompletion script for the specified shell


.SH SYNOPSIS
\fBevolve completion [flags]\fP


.SH DESCRIPTION
Generate the autocompletion script for evolve for the specified shell.
See each sub-command's help for details on how to use the generated script.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--json\fP[=false]
	emit machine-readable JSONL progress on stdout

.PP
\fB--layout\fP="auto"
	repository layout: auto, marketplace, multi, or single

.PP
\fB--results-format\fP=""
	format for results files and the EVALUATION rollup: json, jsonc, or yaml (default: config results_format or json)

.PP
\fB--root\fP=""
	repository root to operate on (default: walk up from the current directory)

.PP
\fB--telemetry-dir\fP=""
	write OpenTelemetry traces/metrics/logs as JSON to this directory (default: off; overrides OTEL_* env vars)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable debug logging


.SH SEE ALSO
\fBevolve(1)\fP, \fBevolve-completion-bash(1)\fP, \fBevolve-completion-fish(1)\fP, \fBevolve-completion-powershell(1)\fP, \fBevolve-completion-zsh(1)\fP
