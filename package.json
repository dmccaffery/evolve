{
  "name": "evolve",
  "private": true,
  "type": "module",
  "description": "Lint and formatting tools for the evolve CLI.",
  "license": "MIT",
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "markdownlint-cli2 '**/*.md'",
    "lint:fix": "markdownlint-cli2 --fix '**/*.md'"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.0.0"
  }
}
